---
import { getCollection } from "astro:content";
import CategoryLayout from "../../layouts/CategoryLayout.astro";
import { getProductImageMap, resolveCategoryProductImages } from "../../lib/products";

export async function getStaticPaths() {
  const [categories, productImageMap] = await Promise.all([
    getCollection("product-categories"),
    getProductImageMap(),
  ]);

  return categories.map((category) => ({
    params: { slug: category.data.slug },
    props: {
      category,
      products: resolveCategoryProductImages(category.data.products, productImageMap),
    },
  }));
}

const { category, products } = Astro.props;
---

<CategoryLayout
  title={category.data.title}
  slug={category.data.slug}
  description={category.data.description}
  subcategories={category.data.subcategories}
  products={products}
  breadcrumb={category.data.breadcrumb}
/>
