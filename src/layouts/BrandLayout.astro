---
import PageLayout from "./PageLayout.astro";
import type { Brand } from "../data/brands";
import type { ProductSummary } from "../lib/products";

interface Props {
  brand: Brand;
  products: ProductSummary[];
}

const { brand, products } = Astro.props;
---

<PageLayout
  title={`${brand.name} — Center Industrial Supply Corporation`}
  description={brand.description}
  pageTitle={brand.name}
  breadcrumb={`<a href="/">Home</a> / <a href="/#brands">Brands</a> / ${brand.name}`}
  subtitle={brand.tagline}
>
  <main class="cisc-section">
    <div class="cisc-container">
      <div class="cisc-brand-hero">
        <div class="cisc-brand-hero__logo">
          {
            brand.logo ? (
              <img src={brand.logo} alt={`${brand.name} logo`} width="320" height="107" />
            ) : (
              <span class="cisc-brand-hero__wordmark">{brand.name}</span>
            )
          }
        </div>
        <div class="cisc-brand-hero__copy">
          <p>{brand.description}</p>
        </div>
      </div>

      <div class="cisc-brand-products__header">
        <h2>Products from {brand.name}</h2>
        <p>{products.length} {products.length === 1 ? "product" : "products"} in catalog</p>
      </div>

      {
        products.length > 0 ? (
          <div class="cisc-product-grid">
            {products.map((product) => (
              <a class="cisc-product-card" href={product.href}>
                <div class="cisc-product-card__img">
                  <img
                    src={`/${product.image}`}
                    alt={product.name}
                    loading="lazy"
                    width="300"
                    height="300"
                  />
                </div>
                <div class="cisc-product-card__body">
                  <h3>{product.name}</h3>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="cisc-brand-empty">
            Product listings for {brand.name} are being updated. Please <a href="/contact-us/">contact us</a> for
            current availability.
          </p>
        )
      }
    </div>
  </main>
</PageLayout>
