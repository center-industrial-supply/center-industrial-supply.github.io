---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  legacy?: boolean;
}

const { title, description, legacy = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#022b33" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Source+Sans+3:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/site.css" />
    {legacy && <link rel="stylesheet" href="/assets/css/legacy.css" />}
    <link rel="icon" href="/wp-content/uploads/2020/10/small-brand-logo-1024x194.png" />
    {legacy && <script is:inline defer src="/assets/js/layout.js"></script>}
  </head>
  <body class:list={["cisc-body", legacy && "cisc-legacy"]}>
  {!legacy && <Header />}
    <slot />
  {!legacy && <Footer />}
    <script is:inline src="/assets/js/site.js"></script>
  </body>
</html>
